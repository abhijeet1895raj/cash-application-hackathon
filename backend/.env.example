# Set true for demo mode (no Azure needed), false to run real AI agents
USE_FIXTURES=true

# Azure AI Foundry - required when USE_FIXTURES=false
AZURE_AI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_API_KEY=your_api_key_here
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Model routing - which deployment name to use per agent
MODEL_BANK_AGENT=gpt-4o-mini
MODEL_AR_AGENT=gpt-4o-mini
MODEL_RECON_AGENT=gpt-4o
MODEL_REASONING_AGENT=gpt-4o
MODEL_POSTING_AGENT=gpt-4o

# Optional Azure services (leave blank to skip)
AZURE_STORAGE_ACCOUNT_URL=
APPLICATIONINSIGHTS_CONNECTION_STRING=